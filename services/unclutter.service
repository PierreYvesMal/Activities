[Unit]
Description=Hide mouse cursor (unclutter)
After=graphical.target
Wants=graphical.target

[Service]
Type=simple
User=rpy

Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/rpy/.Xauthority

ExecStart=/usr/bin/unclutter -idle 1 -root

Restart=always
RestartSec=2

[Install]
WantedBy=graphical.target
